rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validGenre(genre) {
      return genre in ['自由詩', '叙情詩', '散文詩', '短詩', 'その他'];
    }

    function validProfile(data) {
      return data.keys().hasOnly(['displayName', 'bio', 'createdAt'])
        && data.displayName is string
        && data.displayName.size() >= 1
        && data.displayName.size() <= 30
        && data.bio is string
        && data.bio.size() <= 200
        && data.createdAt is string;
    }

    function validPoem(data) {
      return data.keys().hasOnly(['authorId', 'title', 'genre', 'tags', 'body', 'createdAt', 'updatedAt'])
        && data.authorId is string
        && data.title is string
        && data.title.size() >= 1
        && data.title.size() <= 80
        && data.body is string
        && data.body.size() >= 10
        && data.body.size() <= 2000
        && validGenre(data.genre)
        && data.tags is list
        && data.tags.size() <= 8
        && data.createdAt is string
        && data.updatedAt is string;
    }

    function validComment(data) {
      return data.keys().hasOnly(['poemId', 'authorId', 'body', 'createdAt'])
        && data.poemId is string
        && data.authorId is string
        && data.body is string
        && data.body.size() >= 1
        && data.body.size() <= 300
        && data.createdAt is string;
    }

    function validLike(data) {
      return data.keys().hasOnly(['poemId', 'userId', 'createdAt'])
        && data.poemId is string
        && data.userId is string
        && data.createdAt is string;
    }

    match /profiles/{userId} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && validProfile(request.resource.data);
      allow delete: if false;
    }

    match /poems/{poemId} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.authorId
        && validPoem(request.resource.data);
      allow update: if signedIn()
        && request.auth.uid == resource.data.authorId
        && request.auth.uid == request.resource.data.authorId
        && request.resource.data.createdAt == resource.data.createdAt
        && validPoem(request.resource.data);
      allow delete: if signedIn()
        && request.auth.uid == resource.data.authorId;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.authorId
        && validComment(request.resource.data);
      allow update: if false;
      allow delete: if signedIn()
        && request.auth.uid == resource.data.authorId;
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.userId
        && validLike(request.resource.data);
      allow update: if false;
      allow delete: if signedIn()
        && request.auth.uid == resource.data.userId;
    }
  }
}
